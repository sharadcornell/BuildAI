# BuildAI — environment variables (names only; no real values here).
# Copy to .env.local and fill in. .env.local is git-ignored — NEVER commit real values.
# NEXT_PUBLIC_* are exposed to the browser; everything else is server-only.

# ---- Supabase (auth + Postgres + form storage) — REQUIRED ----
NEXT_PUBLIC_SUPABASE_URL=
# Newer "publishable" anon key. The app also falls back to the legacy
# NEXT_PUBLIC_SUPABASE_ANON_KEY name if that's what your project still uses.
NEXT_PUBLIC_SUPABASE_PUBLISHABLE_KEY=
# Service-role key — SERVER ONLY (privileged writes / admin actions). Never ship to the client.
SUPABASE_SERVICE_ROLE_KEY=

# ---- Site ----
# Public base URL used for absolute links / OG metadata (e.g. https://buildai.global
# in prod, http://localhost:3000 in dev).
NEXT_PUBLIC_SITE_URL=

# ---- Email (Resend) — lead notifications. REQUIRED for emails ----
RESEND_API_KEY=
LEAD_NOTIFICATION_TO=you@example.com

# ---- Anti-spam (Cloudflare Turnstile) — DEFERRED (not wired yet) ----
# Only the honeypot is active today. Leave blank unless/until Turnstile is implemented.
NEXT_PUBLIC_TURNSTILE_SITE_KEY=
TURNSTILE_SECRET_KEY=

# ============================================================================
# AI layer (LiteLLM gateway + Langfuse traces) — DEFERRED / OPTIONAL for now.
# Phase 3A stores AI-access METADATA only. With these unset, the app shows
# "not configured" and issues NO live keys. Live issuance is Phase 3B.
# All of these are SERVER-ONLY (no NEXT_PUBLIC_ prefix) — never exposed to the browser.
# ============================================================================
# LiteLLM proxy base URL (the app talks to the proxy, not to providers directly).
LITELLM_PROXY_BASE_URL=
# LiteLLM master/admin key — SERVER ONLY.
LITELLM_MASTER_KEY=
# Langfuse observability keys — SERVER ONLY (secret key must never reach the client).
LANGFUSE_PUBLIC_KEY=
LANGFUSE_SECRET_KEY=
LANGFUSE_OTEL_HOST=

# ---- Providers (OpenRouter, etc.) — DEFERRED ----
# NOTE: an OPENROUTER_API_KEY (or any raw provider key) belongs in the LiteLLM
# PROXY's environment, NOT in this Next.js app and NEVER in the browser. Students
# only ever receive BuildAI virtual keys via the gateway — never raw provider keys.
# Do not add OPENROUTER_API_KEY to this file.
