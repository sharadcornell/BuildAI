# BuildAI — environment variables (names only; no real values here).
# Copy to .env.local and fill in. .env.local is git-ignored — NEVER commit real values.
# NEXT_PUBLIC_* are exposed to the browser; everything else is server-only.

# ---- Supabase (auth + Postgres + form storage) — REQUIRED ----
NEXT_PUBLIC_SUPABASE_URL=
# Newer "publishable" anon key. The app also falls back to the legacy
# NEXT_PUBLIC_SUPABASE_ANON_KEY name if that's what your project still uses.
NEXT_PUBLIC_SUPABASE_PUBLISHABLE_KEY=
# Service-role key — SERVER ONLY (privileged writes / admin actions). Never ship to the client.
SUPABASE_SERVICE_ROLE_KEY=

# ---- Site ----
# Public base URL used for absolute links / OG metadata (e.g. https://buildai.global
# in prod, http://localhost:3000 in dev).
NEXT_PUBLIC_SITE_URL=

# ---- Auth: Google sign-in (Supabase OAuth) — FEATURE-FLAGGED, OFF by default ----
# Email + password login always works. Google is gated by this flag so it can be
# shipped dark and switched on later WITHOUT real credentials in this app.
#   - Leave "false" (or unset) → the login page shows a disabled "Continue with
#     Google" button + "coming soon"; no OAuth call is ever made.
#   - Set "true" ONLY AFTER the Supabase Google provider is configured.
# The Google OAuth client ID/secret are NOT set here — they live in the Supabase
# Dashboard → Authentication → Providers → Google. This app never holds the Google
# client secret.
NEXT_PUBLIC_GOOGLE_AUTH_ENABLED=false
# Optional. Full callback URL Google returns to (our SSR route is /auth/callback).
# If unset, it's derived safely from NEXT_PUBLIC_SITE_URL, else the live origin —
# so you usually don't need to set this. In Supabase, add your site + redirect URLs
# under Authentication → URL Configuration for EVERY environment: e.g.
# http://localhost:3000, the Vercel preview URL, and the production domain.
# NEXT_PUBLIC_AUTH_REDIRECT_URL=

# ---- Email (Resend) — lead notifications. REQUIRED for emails ----
RESEND_API_KEY=
LEAD_NOTIFICATION_TO=you@example.com

# ---- Anti-spam (Cloudflare Turnstile) — DEFERRED (not wired yet) ----
# Only the honeypot is active today. Leave blank unless/until Turnstile is implemented.
NEXT_PUBLIC_TURNSTILE_SITE_KEY=
TURNSTILE_SECRET_KEY=

# ============================================================================
# AI layer (LiteLLM gateway + Langfuse traces) — DEFERRED / OPTIONAL for now.
# Phase 3A stores AI-access METADATA only. With these unset, the app shows
# "not configured" and issues NO live keys. Live issuance is Phase 3B.
# Server-only vars below (no NEXT_PUBLIC_ prefix) — never exposed to the browser.
# ============================================================================
# App-level feature flag for the AI-key layer (Phase 4B). OFF by default.
#   - "false"/unset → student card shows "AI API access is not enabled yet";
#                     admin shows "Feature disabled". No issuance is implied.
#   - "true" but LiteLLM env below absent → admin shows "LiteLLM not configured".
#   - "true" AND LiteLLM env present → "Ready for Phase 3B" (live issuance later).
NEXT_PUBLIC_AI_KEYS_ENABLED=false
# LiteLLM proxy base URL (the app talks to the proxy, not to providers directly).
LITELLM_PROXY_BASE_URL=
# LiteLLM master/admin key — SERVER ONLY.
LITELLM_MASTER_KEY=
# Langfuse observability keys — SERVER ONLY (secret key must never reach the client).
LANGFUSE_PUBLIC_KEY=
LANGFUSE_SECRET_KEY=
LANGFUSE_OTEL_HOST=

# ---- Providers (OpenRouter, etc.) — DEFERRED ----
# NOTE: an OPENROUTER_API_KEY (or any raw provider key) belongs in the LiteLLM
# PROXY's environment/config, NOT in this Next.js app. Specifically:
#   - Do NOT add OPENROUTER_API_KEY to this file or any .env the app reads.
#   - Do NOT expose the OpenRouter key to the browser (never a NEXT_PUBLIC_ var).
#   - Do NOT store the OpenRouter key (or any raw provider key) in Supabase.
#   - Do NOT commit provider keys anywhere in this repo.
# Students only ever receive BuildAI virtual keys via the LiteLLM gateway — never
# raw provider keys. OpenRouter sits UPSTREAM of LiteLLM; the app only ever talks
# to the LiteLLM proxy (LITELLM_PROXY_BASE_URL), never to OpenRouter directly.
